<h2>任务仓库 📦</h2>
<div class="task-table-container">
  <table class="task-table" >
  <thead>
    <tr class="task-header">
      <th></th>
      <th>标题</th>
      <th>DDL</th>
      <th>优先级</th>
      <th>标签</th>
      <th>操作</th>
    </tr>
  </thead>
  <tbody>
    <% @tasks.each do |task| %>
      <tr class="task-row <%= 'completed' if task[:state] == 0 %>">
        <!-- <td><%= '✅' if task[:state].zero? %></td> -->
        <td>
          <%= @sicon[task[:state]] %>
        </td>
        <td><a href="/tasks/<%= task[:id] %>" style="color: inherit; text-decoration: none"><%= task[:title] %></a></td>
        <td><%= task[:deadline] || '<span class="text-gray">-无DDL-</span>' %></td>
        <td><%= '⭐' * (task[:priority] || 0) %></td>
        <td><%= task[:tag] || '-' %></td>
        <td>
          <a href="/tasks/<%= task[:id] %>/edit" class="btn btn-sm">✏️ 编辑</a>
          <form action="/tasks/<%= task[:id] %>" method="post" style="display:inline;">
            <input type="hidden" name="_method" value="delete">
            <button type="submit"
                    class="btn btn-sm btn-danger"
                    onclick="return confirm('确定要, 删除这个任务吗?');">❌ 删除</button>
          </form>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
</div>

<button id="scroll-to-add" class="btn-fixed scroll-to-bottom" aria-label="滚动到添加任务">
  ⬇️
</button>

<%# 新建任务表单 %>
<h2 id="add-task-heading">➕ 添加新任务</h2>
<form action="/tasks" method="post" class="task-form">
  <!-- 标题 (必填) -->
  <label>✨ 任务标题</label>
  <input type="text" name="title" placeholder="今天, 要做什么~呢?" required>

  <!-- 截止日期 -->
  <label>📅 截止日期 (可选)</label>
  <input type="date" name="deadline">

  <!-- 重要度 (用下拉菜单更直观) -->
  <label>⭐ 重要程度</label>
  <select name="priority">
    <option value="" selected>-无-</option>
    <option value="1">⭐ 普通</option>
    <option value="2">⭐⭐ 重要</option>
    <option value="3">⭐⭐⭐ 很重要</option>
    <option value="4">⭐⭐⭐⭐ 非常重要</option>
    <option value="5">⭐⭐⭐⭐⭐ 切身大事!</option>
  </select>

  <!-- 标签 -->
  <label>🏷️ 分类标签 (如：学习 / 工作)</label>
  <input type="text" name="tag" placeholder="按回车或逗号分隔多个标签">

  <!-- Readme (多行备注) -->
  <label>📝 详细说明 (可选)</label>
  <textarea name="readme" placeholder="记录灵感、步骤或备注..."></textarea>

  <!-- 提交按钮 -->
  <button type="submit" class="btn">✓ 添加任务</button>
</form>

<script>
  document.getElementById('scroll-to-add').addEventListener('click', () => {
    const heading = document.getElementById('add-task-heading');
    heading.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });
</script>
