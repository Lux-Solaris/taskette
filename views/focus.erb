<% unless @task.nil? %>
  <!-- 专注小窝标题 -->
  <h2 class="text-center">🍅 专注模式</h2>
  <div class="task-form">
    <!-- 任务标题 (超大字!) -->
    <h1 class="text-center" style="margin: 1rem 0; color: var(--color-primary);"><%= @task[:title] %></h1>
    
    <!-- 任务小标签 -->
    <div class="text-center" style="margin-bottom: 1.5rem;">
      <% if @task[:tag] %>
        <span class="btn" style="background: var(--color-secondary); margin: 0.2rem;">🏷️ <%= @task[:tag] %></span>
      <% end %>
      <% if @task[:priority] %>
        <span class="btn" style="background: var(--color-primary); margin: 0.2rem;">
          ⭐ <%= '★' * @task[:priority] %>
        </span>
      <% end %>
      <% if @task[:deadline] %>
        <span class="text-gray">📅 截止：<%= @task[:deadline] %></span>
      <% else %>
        <span class="text-gray">♾️ 无期限任务</span>
      <% end %>
    </div>

    <!-- README 进度流 (时间顺序) -->
    <div style="margin-bottom: 1rem;">
      <h3 style="display: flex; align-items: center; margin: 0;">
        📝 任务记录
        <button id="add-readme-btn" style="all: unset; font-size: 1.5rem; cursor: pointer; padding: 0.2rem 0.5rem; border-radius: 8px; user-select: none; margin-left: 0.5rem;">
          ➕
        </button>
      </h3>
    </div>
    
    <!-- README 表单 (默认隐藏) -->
    <div id="readme-form" style="display: none; margin: 1rem 0; padding: 1rem; background: var(--color-bg-surface); border-radius: 12px; box-shadow: 0 2px 8px var(--shadow-sm);">
      <form action="/tasks/<%= @task[:id] %>/readme" method="post">
        <input type="hidden" name="_method" value="put">
        <textarea name="readme" placeholder="记录你的任务进展..." style="width: 100%; min-height: 100px; margin-bottom: 1rem;"></textarea>
        <div style="display: flex; gap: 0.5rem; justify-content: center;">
          <button type="button" id="cancel-readme-btn" class="btn" style="background: var(--color-bg-disabled);">
            取消
          </button>
          <button type="submit" class="btn" style="background: var(--color-success);">
            保存记录
          </button>
        </div>
      </form>
    </div>
    
    <% if @readmes.empty? %>
      <p class="text-center text-gray" style="padding: 1.5rem;">📭 还没有记录哦~ 专注后记得添加喵！</p>
    <% else %>
      <div style="max-height: 300px; overflow-y: auto; padding: 0.5rem;">
        <% @readmes.each do |rm| %>
          <div class="task-card" style="margin-bottom: 0.8rem; padding: 0.8rem;">
            <div style="font-size: 0.85rem; color: var(--color-text-secondary); margin-bottom: 0.3rem;">
              🕒 <%= rm[:time].strftime('%m/%d %H:%M') if rm[:time] %>
            </div>
            <div><%= rm[:content].gsub(/<[^>]*>/, '').gsub(/\n/, '<br>') %></div>
          </div>
        <% end %>
      </div>
    <% end %>

    <!-- 番茄钟区域 (软乎乎按钮组) -->
    <div class="text-center" style="margin-top: 1.5rem; padding: 1.2rem; background: var(--color-accent); border-radius: 16px;">
      <div id="pomodoro-timer" style="font-size: 2.5rem; font-weight: bold; margin: 0.5rem 0; color: var(--color-text-on-accent);">25:00</div>
      <div>
        <button id="pomo-start" class="btn" style="background: var(--color-error);">▶️ 开始</button>
        <button id="pomo-pause" class="btn" style="background: var(--color-warning); display: none;">⏸️ 暂停</button>
        <button id="pomo-reset" class="btn" style="background: var(--color-secondary);">🔄 重置</button>
      </div>
      <p class="text-gray" style="margin-top: 0.5rem; color: var(--color-text-on-accent);">✨ 专注25分钟，休息5分钟~ 看板酱为你加油!</p>
    </div>

    <!-- 底部操作 -->
    <div class="action-buttons">
      <a href="/" class="btn" style="background: var(--color-secondary);">🏠 回到看板</a>
      <a href="/tasks/<%= @task[:id] %>/edit" class="btn">✏️ 编辑任务</a>
      <form action="/tasks/<%= @task[:id] %>/complete" method="post">
        <button type="submit"
                class="btn"
                style="background: var(--color-success); color: var(--color-text-on-success);"
                onclick="return confirm('确定完成这个任务吗?\n完成后将返回看板~')">
          ✅ 完成任务
        </button>
      </form>
    </div>
  </div>

  <!-- 番茄钟JS (超简单!) -->
  <script>
   let timer, isRunning = false, timeLeft = 25*60, work = true;
   const updateDisplay = () => {
     const m = Math.floor(timeLeft/60), s = timeLeft%60;
     document.getElementById('pomodoro-timer').textContent = 
       `${m.toString().padStart(2,'0')}:${s.toString().padStart(2,'0')}`;
   };
   document.getElementById('pomo-start').onclick = () => {
     if (!isRunning) {
       isRunning = true;
       document.getElementById('pomo-start').style.display = 'none';
       document.getElementById('pomo-pause').style.display = 'inline-block';
       timer = setInterval(() => {
         if (timeLeft <= 0) {
           /* clearInterval(timer); */
           if (work) { alert('🌸 番茄时间结束! 休息一下吧~'); timeLeft=5*60; work = false; }
           else { alert('🍅 休息时间结束! 开始番茄工作吧~'); timeLeft=25*60; work = true; }
        }
         else timeLeft--;
         updateDisplay();
       }, 1000);
     }
   };
   document.getElementById('pomo-pause').onclick = () => {
     clearInterval(timer); isRunning = false;
     document.getElementById('pomo-pause').style.display = 'none';
     document.getElementById('pomo-start').style.display = 'inline-block';
   };
   document.getElementById('pomo-reset').onclick = () => {
    clearInterval(timer); isRunning = false; timeLeft = (work ? 25 : 5)*60
    document.getElementById('pomo-pause').style.display = 'none';
    document.getElementById('pomo-start').style.display = 'inline-block';
    updateDisplay();
  };

  // README 表单交互
  const addReadmeBtn = document.getElementById('add-readme-btn');
  const cancelReadmeBtn = document.getElementById('cancel-readme-btn');
  const readmeForm = document.getElementById('readme-form');

  if (addReadmeBtn && cancelReadmeBtn && readmeForm) {
    addReadmeBtn.addEventListener('click', () => {
      readmeForm.style.display = 'block';
      addReadmeBtn.style.display = 'none';
    });

    cancelReadmeBtn.addEventListener('click', () => {
      readmeForm.style.display = 'none';
      addReadmeBtn.style.display = 'inline-block';
    });
  }
  </script>
<% else %>
  <h2 class="text-center">🍅 专注模式</h2>
  <div class="task-form">
    <h1 class="text-center" style="margin: 1rem 0; color: var(--color-primary);">🌸 暂时没有任务哦~</h1>
  </div>
<% end %>
