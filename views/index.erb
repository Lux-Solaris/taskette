<!-- <p><%= greetings %></p> -->
<h2>今日任务看板 📝</h2>
<div class="task-list">
  <% task_list = select_tasks.each do |task| %>
    <div class="task-card">
      <h3><a href="/focus?id=<%= task[:id] %>" style="color: inherit; text-decoration: none"><%= task[:title] %> 🌸</a></h3>
      <% unless task[:deadline].nil? %>
        <p class="deadline">截止: <%= task[:deadline] %></p>
      <% end %>
      <% unless task[:priority].nil? %>
        <p>重要度: <%= '⭐' * task[:priority] %></p>
      <% end %>
      <% unless task[:tag].nil? %>
        <p>标签: <%= task[:tag] %></p>
      <% end %>
      <a href="/tasks/<%= task[:id] %>/complete" class="btn">✓ 标记完成</a>
    </div>
  <% end %>
  <% unless task_list.empty? %>
    <p class="hint">✨ 点击卡片左下角“✓”标记完成!</p>
  <% else %>
    <p class="hint">🌸 没有任务啦! 去休息吧~</p>
  <% end %>
</div>
