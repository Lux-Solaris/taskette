<h2>今日任务看板 📝</h2>
<div class="task-list">
  <% @tasks.each do |task| %>
    <div class="task-card <%= 'overdue-card' if task_overdue?(task) %>">
      <% if task_overdue?(task) %>
        <span class="overdue-badge">⚠️ 已过期</span>
      <% end %>
      <h3><a href="/focus?id=<%= task[:id] %>" style="color: inherit; text-decoration: none"><%= task[:title] %> 🌸</a></h3>
      <% unless task[:deadline].nil? %>
        <p class="deadline <%= 'overdue-text' if task_overdue?(task) %>">截止: <%= task[:deadline] %></p>
      <% end %>
      <% unless task[:priority].nil? %>
        <p>重要度: <%= '⭐' * task[:priority] %></p>
      <% end %>
      <% unless task[:tag].nil? %>
        <p>标签: <%= task[:tag] %></p>
      <% end %>
      <form action="/tasks/<%= task[:id] %>/complete" method="post" style="display:inline;">
        <button type="submit" class="btn">✓ 标记完成</button>
      </form>
    </div>
  <% end %>
  <% unless @tasks.empty? %>
    <p class="hint">✨ 点击卡片左下角"✓"标记完成!</p>
  <% else %>
    <p class="hint">🌸 没有任务啦! 去休息吧~</p>
  <% end %>
</div>
